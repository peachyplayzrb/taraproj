def remove_punctuation(text):
    # Keep hyphens for now — hyphenated terms like "self-attention" are important
    text = re.sub(r'[^\w\s\-]', '', text)
    # Remove standalone hyphens
    text = re.sub(r'\s-\s', ' ', text)
